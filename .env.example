# DEVELOPMENT or PRODUCTION
ENVIRONMENT=DEVELOPMENT

# database url (sqlite path in out case)
DATABASE_URL=data/headlessgit.db
AUTO_MIGRATE=true

# listener ports
CONTROL_PORT=4001
GIT_HTTP_PORT=4000
GIT_SSH_PORT=2222

# where the bare repos are stored
REPO_ROOT=data/repos
# where the host key file is kept (for ssh)
SSH_HOST_KEY_PATH=data/ssh/host_ed25519


# enable the LFS endpoints (batch + verify + object transfer)
LFS_ENABLED=false
# storage backend: disk or s3
LFS_STORAGE_TYPE=disk
# where LFS objects live when LFS_STORAGE_TYPE=disk
LFS_ROOT=data/lfs
# externally-reachable base URL of the git HTTP server
# required when LFS_ENABLED=true
LFS_PUBLIC_URL=

# random token for the seeded admin service account, 
# which can be generated, for example with openssl rand -hex 32
# only its hash is stored. if it rotates -> it updates admin account on restart 
# if empty -> no admin seeded
ADMIN_TOKEN=
