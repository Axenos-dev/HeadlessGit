# DEVELOPMENT or PRODUCTION
ENVIRONMENT=DEVELOPMENT

# database url (sqlite path in out case)
DATABASE_URL=data/headlessgit.db
AUTO_MIGRATE=true

# listener ports
CONTROL_PORT=4001
GIT_HTTP_PORT=4000
GIT_SSH_PORT=2222

# where the bare repos are stored
REPO_ROOT=data/repos
# where the host key file is kept (for ssh)
SSH_HOST_KEY_PATH=data/ssh/host_ed25519

# background maintenance intervals (go duration syntax, e.g. "30m", "12h")
# a zero duration ("0") disables the loop
TOKEN_GC_INTERVAL=1h
REPO_GC_INTERVAL=5h
# goroutines delivering webhook events
WEBHOOK_WORKERS=3


# enable the LFS endpoints (batch + verify + object transfer)
LFS_ENABLED=false
# storage backend: disk or s3
LFS_STORAGE_TYPE=disk
# where LFS objects live when LFS_STORAGE_TYPE=disk
LFS_ROOT=data/lfs
# externally-reachable base URL of the git HTTP server
# required when LFS_ENABLED=true
LFS_PUBLIC_URL=

# S3-compatible object storage (AWS S3, Cloudflare R2, MinIO, ...)
LFS_S3_BUCKET=
# "us-east-1" for AWS, "auto" for Cloudflare R2
LFS_S3_REGION=
# host[:port], no scheme. e.g. "<account>.r2.cloudflarestorage.com" for R2
LFS_S3_ENDPOINT=
LFS_S3_ACCESS_KEY_ID=
LFS_S3_SECRET_ACCESS_KEY=
# use https to reach the endpoint
LFS_S3_USE_SSL=true
# force path-style addressing
LFS_S3_USE_PATH_STYLE=false
# optional prefix prepended to all object keys in the bucket
LFS_S3_KEY_PREFIX=

# random token for the seeded admin service account, 
# which can be generated, for example with openssl rand -hex 32
# only its hash is stored. if it rotates -> it updates admin account on restart 
# if empty -> no admin seeded
ADMIN_TOKEN=
